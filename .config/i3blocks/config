# --- CENTER BLOCK ---
# Define the title block first logically, but ensure all right-aligned blocks
# are defined *after* it in this file.
[title]
command=~/Scripts/window_title.sh
interval=1
align=center 
separator=false

[gap]
command=echo "                                                                                                                         "
interval=once
min_width=5
align=left
separator=false

# --- RIGHT BLOCKS ---
# These appear after the center block definition.
# Using align=right ensures they stack from the right edge.

# [wifi]
# command=~/Scripts/wifi_status.sh
# interval=5
# align=right
# separator=false

[gap]
command=echo " "
interval=once
min_width=5
align=right
separator=false

