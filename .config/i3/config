# --- Universal Scratchpad Setup ---

# Define modes for multi-key sequences
# ------------------------------------
# Mode entered by Alt+i
mode "scratchpad_i_launcher" {
    # Press 'i' inside this mode to launch Kitty into the scratchpad
    bindsym i exec --no-startup-id kitty --title SCRATCHPAD_KITTY; mode "default"

    # Allow Esc to exit the mode without action
    bindsym Escape mode "default"
    # REMOVED: bindsym $mod+s mode "default"
}

# Mode entered by Alt+p
mode "scratchpad_p_launcher" {
    # Press 'p' inside this mode to launch Leafpad into the scratchpad
    bindsym p exec --no-startup-id Leafpad; mode "default"
    # Or just 'exec ... Leafpad' if chaining failed

    # Allow Esc to exit the mode without action
    bindsym Escape mode "default"
}

# Bindings to enter the modes
bindsym $mod+i mode "scratchpad_i_launcher"
bindsym $mod+p mode "scratchpad_p_launcher"

# Rule for the specifically titled Kitty instance (still needed to hide initially)
for_window [title="^SCRATCHPAD_KITTY$"] floating enable, resize set 70 ppt 70 ppt, move scratchpad

# Rule for Leafpad (using class name) (still needed to hide initially)
# CAVEAT: This rule applies to *any* Leafpad window.
for_window [class="^Leafpad$"] floating enable, resize set 60 ppt 60 ppt, move scratchpad

# --- Specific Scratchpad Toggles ---

# Keybinding to specifically toggle the SCRATCHPAD_KITTY window
# Example: Alt+Shift+k
bindsym $mod+Shift+i [title="^SCRATCHPAD_KITTY$"] scratchpad show

# Keybinding to specifically toggle the Leafpad scratchpad window
# Example: Alt+Shift+p
# CAVEAT: This targets by class. If you run another Leafpad instance normally,
# this key might accidentally grab that one sometimes. Works best if you
# primarily run Leafpad via the scratchpad launcher.
bindsym $mod+Shift+p [class="^Leafpad$"] scratchpad show

# --- Generic Scratchpad Toggle ---
# Use a *separate* key to toggle the visibility of whatever window was last focused on the scratchpad.
# Alt+grave (`)` is often a good candidate.
bindsym $mod+grave scratchpad show

# --- End Universal Scratchpad Setup ---


# Compositor
exec --no-startup-id picom --config ~/.config/picom/picom.conf

# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex --autostart --environment i3

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
exec --no-startup-id nm-applet

# Bluetooth Manager Applet
exec --no-startup-id blueman-applet

# Lock Screen (Mod+Control+l)
bindsym $mod+Control+l exec loginctl lock-session

# Take a screenshot of a selected region (uses slop)
bindsym $mod+Shift+s exec --no-startup-id maim -s ~/Pictures/Screenshots/screenshot-$(date +%s).png

# Use pactl to adjust volume in PulseAudio.
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# Volume Control

# Mute Toggle (Mod+F10)
# We use 'wpctl' (WirePlumber Control) instead of 'pactl' because it is
# the native tool for our PipeWire setup.
# '&& pkill -RTMIN+10 i3blocks' sends a signal to i3blocks to update the
# volume text immediately, rather than waiting for the refresh interval.
bindsym $mod+F10 exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && pkill -RTMIN+10 i3blocks

# Volume Lower (Mod+F11)
# Decreases volume by 5%. The '@DEFAULT_AUDIO_SINK@' variable automatically
# targets whatever output is currently selected (Headphones/Speakers),
# so we don't need to specify hardware IDs.
bindsym $mod+F11 exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && pkill -RTMIN+10 i3blocks

# Volume Raise (Mod+F12)
# We add the '-l 1.5' flag to limit the maximum volume to 150%.
# This prevents accidentally blowing out speakers or damaging hearing
# if you hold the key down too long.
bindsym $mod+F12 exec --no-startup-id wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+ && pkill -RTMIN+10 i3blocks


